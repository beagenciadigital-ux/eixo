# Next.js carrega .env e .env.local; no `next.config.ts` o projeto força a mesma ordem
# (`.env.local` ganha no localhost) para a API / TypeORM verem DATABASE_URL, JWT_SECRET, etc.
# EasyPanel/Docker: define as mesmas chaves no painel — não dependas de ficheiro .env dentro da imagem.

NODE_ENV=development

# PostgreSQL — com DATABASE_URL, o TypeORM usa só a URL (DB_* são fallback).
# `postgres://` e `postgresql://` são aceites. Postgres interno (sem SSL): ?sslmode=disable
# Reforço opcional: PGSSLMODE=disable  ou  DB_SSL=false
# DATABASE_URL=postgresql://USER:PASSWORD@HOST_DOCKER:5432/eixo?sslmode=disable

DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=promisance

# DB_SSL=true

# Primeira subida com base vazia: TYPEORM_SYNC pode ficar por omissão (true) para criar tabelas.
# Depois de estável: TYPEORM_SYNC=false e migrações explícitas (recomendado em produção).
# TYPEORM_SYNC=false
# Base vazia em prod: opcionalmente criar jogo default (senão só via admin)
# SEED_DEFAULT_GAME=true

JWT_SECRET=change-me-in-production

# --- EasyPanel / stack Docker (resumo) ---
# NODE_ENV=production
# JWT_SECRET=(valor forte, não commits)
# DATABASE_URL=postgresql://USER:PASS@nome_servico_postgres:5432/eixo?sslmode=disable
# ou só DB_HOST / DB_PORT / DB_USERNAME / DB_PASSWORD / DB_DATABASE no mesmo rede Docker
# ORIGIN=https://dominio-publico-da-app   (CORS + cookies; acrescenta ao default se precisares)
# Container já expõe PORT=3000 e HOSTNAME=0.0.0.0 no Dockerfile.
# NEXT_PUBLIC_API_ORIGIN: deixa vazio se o browser chama o mesmo host (usa /api). Só precisas
# se a API estiver noutro domínio — e aí tens de rebuildar com essa var (Next inlines NEXT_PUBLIC_*).

# --- Segredo dos crons HTTP (/api/cron/*) — obrigatório em produção se usares agendador ---
# O mesmo valor vai na variável da app E no header Bearer do job que chama o endpoint.
CRON_SECRET=change-me-cron-secret

# EasyPanel: cron a cada 1 minuto (turnos)
# 1) Gera um CRON_SECRET forte e cola em "Environment" do serviço da app (esta chave).
# 2) No EasyPanel: Scheduled Tasks / Cron (ou serviço "Cron" do stack), agenda:
#    minuto: *    hora: *    dia: *    mês: *    dia-semana: *   (= expressão cron * * * * *)
# 3) Comando (HTTPS — recomendado; substitui o domínio):
#    curl -fsS -H "Authorization: Bearer SEU_CRON_SECRET_AQUI" "https://teu-dominio.com/api/cron/turns"
#    Rede interna Docker (mesmo stack; substitui NOME_DO_SERVICO_DA_APP):
#    curl -fsS -H "Authorization: Bearer SEU_CRON_SECRET_AQUI" "http://NOME_DO_SERVICO_DA_APP:3000/api/cron/turns"
# O endpoint /api/cron/turns só aplica turnos quando passou turnsFreq (minutos) desde lastTurnsUpdate;
# chamares a cada minuto serve para não falhar a janela. Opcional: outros jobs em agendas maiores
#    GET .../api/cron/thirty   (ex.: */30 * * * *)
#    GET .../api/cron/hourly   (ex.: 0 * * * *)
#    GET .../api/cron/daily    (ex.: 0 3 * * *)

# CORS extra (origens separadas por vírgula)
# ORIGIN=https://www.teudominio.com

# Cliente (expõe ao browser — só NEXT_PUBLIC_*)
# NEXT_PUBLIC_API_ORIGIN=
# NEXT_PUBLIC_CONTACT_EMAIL=admin@eixodomal.local
