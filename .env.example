# Next.js carrega .env e .env.local; no `next.config.ts` o projeto força a mesma ordem
# (`.env.local` ganha no localhost) para a API / TypeORM verem DATABASE_URL, JWT_SECRET, etc.

NODE_ENV=development

# PostgreSQL — se defines DATABASE_URL, o TypeORM usa só a URL (os DB_* abaixo são fallback).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=promisance

# DB_SSL=true

# Em produção na Vercel: definir TYPEORM_SYNC=false e usar migrações explícitas.
# TYPEORM_SYNC=false
# Base vazia: em dev o servidor cria um jogo default; em prod opcionalmente:
# SEED_DEFAULT_GAME=true

JWT_SECRET=change-me-in-production

# Crons HTTP (Vercel Cron → /api/cron/*)
CRON_SECRET=change-me-cron-secret

# CORS extra (origens separadas por vírgula)
# ORIGIN=https://www.teudominio.com

# Cliente (expõe ao browser — só NEXT_PUBLIC_*)
# NEXT_PUBLIC_API_ORIGIN=
# NEXT_PUBLIC_CONTACT_EMAIL=admin@eixodomal.local
